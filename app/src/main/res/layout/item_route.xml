<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@drawable/bg_card"
    android:padding="14dp" android:layout_marginBottom="12dp">
    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:id="@+id/name" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/ink" android:textStyle="bold" android:textSize="15sp" />
        <TextView android:id="@+id/meta" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/muted" android:textSize="12sp" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/badge" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_green" android:paddingHorizontal="9dp" android:paddingVertical="3dp"
            android:textColor="@color/green" android:textSize="11sp" android:layout_marginTop="8dp" />
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/fare" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/orange" android:textStyle="bold" android:textSize="17sp" />
        <TextView android:id="@+id/time" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/muted" android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
